    "char_1779643983669": {
      "personality": [
        {
          "subtitle": "Default State",
          "isCollapsed": false,
          "id": "p_1",
          "notes": "Has a very similar personality to her mother. 'Every stranger met is a seed of friendship planted'. A typically positive and upbeat personality. Excited for new opportunities.<div><a href=\"#\" class=\"text-emerald-700 bg-emerald-100/80 font-bold px-1.5 py-0.5 mx-0.5 rounded shadow-sm hover:bg-emerald-200 hover:text-emerald-800 transition-colors inline-flex items-center no-underline cursor-pointer\" contenteditable=\"false\" onclick=\"window.setTab('campaign_npcs'); return false;\">@Tato</a>&nbsp;</div>",
          "title": "Normal Personality"
        },
        {
          "notes": "Eye Color turns from a vibrant green to a dark oak brown. Ties up her hair into a ponytail. Adopts a personality closer to her father; stern, stoic and intensely focused.",
          "title": "Raging Personality",
          "subtitle": "Combat State",
          "isCollapsed": false,
          "id": "p_2"
        },
        {
          "title": "Likes",
          "notes": "Trees, Jungle life, Flora. Her Halberd. Her nomadic lifestyle. Respects animals as a means of hunting for survival.<div><br></div><div>asdf</div><div>asdf</div><div><br></div><div>adsf</div>",
          "id": "p_3",
          "isCollapsed": false,
          "subtitle": "Interests & Preference"
        },
        {
          "notes": "Hobgoblins & Goblins of The Iron Authority. Closed spaces (sealed stone structures, caverns, deep caves).",
          "title": "Dislikes",
          "subtitle": "Fears & Aversions",
          "id": "p_4",
          "isCollapsed": false
        }
      ],
